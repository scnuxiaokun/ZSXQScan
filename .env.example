# 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ========== 必填配置 ==========

# 云开发环境ID（在腾讯云CloudBase控制台获取）
TCB_ENV=

# ========== 可选配置 ==========

# 知识星球 Cookie（用于 GetArticle 获取文章全文）
# 从浏览器 F12 → Network → 复制 api.zsxq.com 请求的 Cookie 头
ZSXQ_COOKIE=

# 监控间隔（毫秒），默认60000(1分钟)
MONITOR_INTERVAL=60000

# 要监控的星球URL列表（JSON数组格式）
# MONITOR_URLS=["https://wx.zsxq.com/group/xxx1","https://wx.zsxq.com/group/xxx2"]
