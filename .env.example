# 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ========== 必填配置 ==========

# MySQL 数据库配置
DB_HOST=sh-cynosdbmysql-grp-xxx.sql.tencentcdb.com
DB_PORT=22871
DB_USER=zsxq_scan_dbuser
DB_PASSWORD=your_password
DB_NAME=temu-tools-prod-3g8yeywsda972fae

# ========== 可选配置 ==========

# 知识星球 Cookie（用于获取文章全文）
# 从浏览器 F12 → Network → 复制 api.zsxq.com 请求的 Cookie 头
ZSXQ_COOKIE=

# 飞书机器人 Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 腾讯云混元大模型 API Key（用于文章洗稿）
# 在腾讯云混元控制台获取：https://console.cloud.tencent.com/hunyuan
HUNYUAN_API_KEY=

# 定时任务配置（cron 表达式）
MONITOR_CRON=*/5 * * * *
TASK_CRON=*/5 * * * *
