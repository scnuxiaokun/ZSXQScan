# 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ========== 必填配置 ==========

# 云开发环境ID（在腾讯云CloudBase控制台获取）
TCB_ENV=

# 浏览器CDP端点（用于Puppeteer连接）
# 格式：ws://host:port 或 wss://host:port
BROWSER_ENDPOINT=

# Chrome路径（如果需要本地启动Chrome）
CHROME_PATH=/usr/bin/google-chrome

# ========== 可选配置 ==========

# 验证码获取接口地址（双卡助手转发接口）
SMS_ENDPOINT=

# 监控间隔（毫秒），默认60000(1分钟)
MONITOR_INTERVAL=60000

# 要监控的星球URL列表（JSON数组格式）
# MONITOR_URLS=["https://wx.zsxq.com/apppzzlxxx1","https://wx.zsxq.com/apppzzlxxx2"]

# 登录手机号（默认18948788411）
LOGIN_PHONE=18948788411
